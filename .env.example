# ──────────────────────────────────────────────────────────────────
#  CityHealth Portal — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit the .env file to source control.
# ──────────────────────────────────────────────────────────────────

# ── Agora App credentials ────────────────────────────────────────
# Agora Console → Project Management → your project
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE

# ── Agora REST API credentials ───────────────────────────────────
# Agora Console → Developer Toolkit → RESTful API → Customer ID / Secret
AGORA_CUSTOMER_ID=YOUR_AGORA_CUSTOMER_ID
AGORA_CUSTOMER_SECRET=YOUR_AGORA_CUSTOMER_SECRET

# ── OpenAI API key (used by the Agora Conversational AI agent) ───
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development


# ── Murf TTS ──────────────────────────────────────────────────
MURF_API_KEY=your_api_key
MURF_VOICE_ID=Anisha


# ── Anam Avatar ─────────────────────────────────────────────
# Used by the Agora Conversational AI avatar configuration.
ANAM_API_KEY=YOUR_ANAM_API_KEY
ANAM_AVATAR_ID=960f614f-ea88-47c3-9883-f02094f70874
# Demo RTC UID for the avatar publisher. Change if it conflicts with your app UID range.
ANAM_AVATAR_RTC_UID=987654321
# Agora RTC token for the Anam avatar UID used as avatar.params.agora_token.
# Leave empty to let the server generate it when App Certificate is configured.
ANAM_AVATAR_AGORA_TOKEN=YOUR_ANAM_AVATAR_AGORA_TOKEN
