# ──────────────────────────────────────────────────────────────────
#  CityHealth Portal — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit the .env file to source control.
# ──────────────────────────────────────────────────────────────────

# ── Agora App credentials ────────────────────────────────────────
# Agora Console → Project Management → your project
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_APP_CERTIFICATE

# ── Agora REST API credentials ───────────────────────────────────
# Agora Console → Developer Toolkit → RESTful API → Customer ID / Secret
AGORA_CUSTOMER_ID=YOUR_AGORA_CUSTOMER_ID
AGORA_CUSTOMER_SECRET=YOUR_AGORA_CUSTOMER_SECRET

# ── OpenAI API key (used by the Agora Conversational AI agent) ───
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY

# ── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development


# ── ElevenLabs TTS ───────────────────────────────────────────────
ELEVENLABS_API_KEY=YOUR_ELEVENLABS_API_KEY
ELEVENLABS_VOICE_ID=YOUR_ELEVENLABS_VOICE_ID
CARTESIA_API_KEY=<APIKEY>
